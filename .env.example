# ── LLM (LM Studio) ──────────────────────────────
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=qwen3-14b

# ── YouTube ──────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Email (sending) ──────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_16_char_app_password
EMAIL_RECIPIENT=your_email@gmail.com

# ── Database ─────────────────────────────────────
DATABASE_URL=sqlite:///./platform.db

# ── Dashboard ────────────────────────────────────
DASHBOARD_PORT=8000

# ── Mailman key people (comma separated) ─────────
KEY_PEOPLE=boss@work.com,important@person.com

# ── Arabic Word of the Day ────────────────────────
# Options: beginner | intermediate | advanced
ARABIC_DIFFICULTY=beginner

# ── InboxCleaner (Bonus Agent) ────────────────────
# Senders to NEVER trash (comma-separated email addresses)
INBOX_CLEANER_WHITELIST=
# Hour of day to run (24h UTC format, default = 2am)
INBOX_CLEANER_RUN_HOUR=2
# Set to true only if you want permanent delete (default = trash)
INBOX_CLEANER_PERMANENT_DELETE=false
